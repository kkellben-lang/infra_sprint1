[Unit]
Description=gunicorn daemon for kittygram
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/infra_sprint1/backend
ExecStart=/home/ubuntu/infra_sprint1/backend/venv/bin/gunicorn \
          --workers 3 \
          --bind 127.0.0.1:8080 \
          kittygram_backend.wsgi:application

[Install]
WantedBy=multi-user.target
